---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header class="site-header" id="main-header">
	<div class="header-container">
		<a href="/" class="brand-link" aria-label="Return to homepage">
			<img 
				src="https://inkbotdesign.com/wp-content/uploads/2015/03/cropped-InkbotDesign_Logomark300.png" 
				alt="Inkbot Design Logomark" 
				width="48" 
				height="48" 
				class="brand-logo"
				fetchpriority="high"
			/>
			<span class="brand-text sr-only">{SITE_TITLE}</span>
		</a>

		<nav aria-label="Primary" class="main-nav" id="primary-navigation">
			<ul class="nav-list">
				<li><HeaderLink href="/">Home</HeaderLink></li>
				<li><HeaderLink href="/branding">Branding</HeaderLink></li>
				<li><HeaderLink href="/web-design">Web Design</HeaderLink></li>
				<li><HeaderLink href="/blog">Insights</HeaderLink></li>
				<li><HeaderLink href="/about">About</HeaderLink></li>
			</ul>
		</nav>

		<div class="header-actions">
			<a href="/contact" class="btn-primary header-cta">Start a Project</a>
			
			<button class="mobile-menu-toggle" aria-expanded="false" aria-controls="primary-navigation" aria-label="Toggle menu">
				<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="menu-icon">
					<line x1="3" y1="12" x2="21" y2="12" class="line-middle"></line>
					<line x1="3" y1="6" x2="21" y2="6" class="line-top"></line>
					<line x1="3" y1="18" x2="21" y2="18" class="line-bottom"></line>
				</svg>
			</button>
		</div>
	</div>
</header>

<style>
	/* --- Sticky Glassmorphism Header --- */
	.site-header {
		position: sticky;
		top: 0;
		z-index: 1000;
		width: 100%;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-color, rgba(0,0,0,0.05));
		transition: background-color 0.3s ease, box-shadow 0.3s ease;
	}

	.header-container {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-sm, 0.5rem) var(--space-md, 1rem);
		height: 80px;
	}

	/* --- Brand Integration --- */
	.brand-link {
		display: flex;
		align-items: center;
		text-decoration: none;
		flex-shrink: 0;
	}

	.brand-logo {
		width: 48px;
		height: 48px;
		border-radius: 50%;
		transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
	}

	.brand-link:hover .brand-logo {
		transform: scale(1.05) rotate(-5deg);
	}

	/* --- Desktop Navigation --- */
	.nav-list {
		display: flex;
		gap: var(--space-md, 1.5rem);
		list-style: none;
		margin: 0;
		padding: 0;
		align-items: center;
	}

	/* Make sure the nested a tags in HeaderLink are styled nicely */
	:global(.nav-list a) {
		text-decoration: none;
		color: var(--text-main, #111827);
		font-weight: 500;
		font-size: 0.95rem;
		padding: 0.5rem 0;
		position: relative;
		transition: color 0.2s ease;
	}

	:global(.nav-list a:hover),
	:global(.nav-list a.active) {
		color: var(--brand-primary, #2337ff);
	}

	/* Animated underline for active/hover states */
	:global(.nav-list a::after) {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 100%;
		height: 2px;
		background-color: var(--brand-primary, #2337ff);
		transform: scaleX(0);
		transform-origin: right;
		transition: transform 0.3s ease;
	}

	:global(.nav-list a:hover::after),
	:global(.nav-list a.active::after) {
		transform: scaleX(1);
		transform-origin: left;
	}

	/* --- Actions & CTA --- */
	.header-actions {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.header-cta {
		display: none; /* Hidden on very small screens, shown on tablet/desktop */
		padding: 0.6rem 1.25rem;
		font-size: 0.9rem;
	}

	.mobile-menu-toggle {
		display: none;
		background: transparent;
		border: none;
		color: var(--text-main);
		cursor: pointer;
		padding: 0.5rem;
		z-index: 1001;
	}

	/* --- Responsive Design --- */
	@media (min-width: 768px) {
		.header-cta {
			display: inline-block;
		}
	}

	@media (max-width: 860px) {
		.mobile-menu-toggle {
			display: block;
		}

		.main-nav {
			position: fixed;
			top: 0;
			right: -100%;
			width: 100%;
			max-width: 400px;
			height: 100vh;
			background: var(--bg-color, #ffffff);
			box-shadow: -5px 0 15px rgba(0,0,0,0.05);
			padding: 80px 2rem 2rem;
			transition: right 0.4s cubic-bezier(0.4, 0, 0.2, 1);
			overflow-y: auto;
		}

		/* When menu is opened via JS class */
		.main-nav.is-open {
			right: 0;
		}

		.nav-list {
			flex-direction: column;
			align-items: flex-start;
			gap: 2rem;
		}

		:global(.nav-list a) {
			font-size: 1.5rem;
		}
	}
</style>

<script>
	// Simple, lightweight script for mobile menu toggle
	const setupMobileMenu = () => {
		const toggle = document.querySelector('.mobile-menu-toggle');
		const nav = document.querySelector('.main-nav');
		
		if (!toggle || !nav) return;

		toggle.addEventListener('click', () => {
			const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
			nav.classList.toggle('is-open');
			
			// Prevent body scroll when menu is open
			document.body.style.overflow = isExpanded ? '' : 'hidden';
		});
	};

	// Runs on initial load
	setupMobileMenu();
	
	// Runs on view transitions (if you use Astro's ViewTransitions later)
	document.addEventListener('astro:page-load', setupMobileMenu);
</script>