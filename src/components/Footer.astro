---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-container">
		
		<div class="footer-grid">
			
			<div class="footer-brand">
				<a href="/" class="logo-link">
					<img 
						src="https://inkbotdesign.com/wp-content/uploads/2015/03/cropped-InkbotDesign_Logomark300.png" 
						alt="Inkbot Design" 
						width="40" 
						height="40" 
						class="footer-logo"
						loading="lazy"
					/>
					<span class="brand-name">{SITE_TITLE}</span>
				</a>
				<p class="brand-description">
					A strategic branding and digital agency partnering with ambitious businesses to drive measurable growth.
				</p>
				<address class="brand-address">
					<strong>Belfast, UK</strong><br />
					<a href="mailto:hello@inkbotdesign.com" class="email-link">hello@inkbotdesign.com</a>
				</address>
			</div>

			<div class="footer-links">
				<h3>Expertise</h3>
				<ul>
					<li><a href="/brand-strategy">Brand Strategy</a></li>
					<li><a href="/identity-design">Identity Design</a></li>
					<li><a href="/web-design">Web Development</a></li>
					<li><a href="/seo">Technical SEO</a></li>
				</ul>
			</div>

			<div class="footer-links">
				<h3>Agency</h3>
				<ul>
					<li><a href="/about">About Us</a></li>
					<li><a href="/portfolio">Portfolio</a></li>
					<li><a href="/blog">Strategic Insights</a></li>
					<li><a href="/contact">Start a Project</a></li>
				</ul>
			</div>

			<div class="footer-links social-column">
				<h3>Connect</h3>
				<div class="social-icons">
					<a href="https://linkedin.com/company/inkbotdesign" target="_blank" rel="noopener noreferrer">
						<span class="sr-only">Follow Inkbot Design on LinkedIn</span>
