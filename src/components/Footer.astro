					</a>
				</div>
			</div>
		</div>

		<hr class="footer-divider" />

		<div class="footer-bottom">
			<p class="copyright">
				&copy; {today.getFullYear()} Inkbot Design. All rights reserved.
			</p>
			<ul class="legal-links">
				<li><a href="/privacy">Privacy Policy</a></li>
				<li><a href="/terms">Terms of Service</a></li>
				<li><a href="/sitemap-index.xml">Sitemap</a></li>
			</ul>
		</div>

	</div>
</footer>

<style>
	/* --- Footer Container --- */
	.site-footer {
		background-color: var(--text-main, #111827); /* Anchors the page with a solid dark base */
		color: var(--surface-color, #f3f4f6);
		padding: var(--space-xl, 4rem) 0 var(--space-md, 1rem) 0;
		font-size: 0.95rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 var(--space-md, 1rem);
	}

	/* --- Grid Layout --- */
	.footer-grid {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr 1fr;
		gap: var(--space-xl, 3rem);
		margin-bottom: var(--space-xl, 3rem);
	}

	@media (max-width: 960px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-lg, 2rem);
		}
		.footer-brand {
			grid-column: 1 / -1; /* Brand spans full width on tablets */
		}
	}

	@media (max-width: 600px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}

	/* --- Brand Column --- */
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		color: #ffffff;
		margin-bottom: var(--space-md, 1rem);
	}

	.footer-logo {
		border-radius: 50%;
	}

	.brand-name {
		font-size: var(--step-1, 1.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.brand-description {
		color: var(--text-muted, #9ca3af);
		max-width: 40ch;
		margin-bottom: var(--space-md, 1rem);
		line-height: 1.5;
	}

	.brand-address {
		font-style: normal;
		color: var(--text-muted, #9ca3af);
		line-height: 1.6;
	}

	.email-link {
		color: #ffffff;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.email-link:hover {
		color: var(--brand-accent, #ff2358);
	}

	/* --- Links Columns --- */
	.footer-links h3 {
		color: #ffffff;
		font-size: 1rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: var(--space-md, 1.25rem);
	}

	.footer-links ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-links a {
		color: var(--text-muted, #9ca3af);
		text-decoration: none;
		transition: color 0.2s ease, transform 0.2s ease;
		display: inline-block;
	}

	.footer-links a:hover {
		color: #ffffff;
		transform: translateX(4px); /* Subtle interaction design */
	}

	/* --- Social Icons --- */
	.social-icons {
		display: flex;
		gap: 1rem;
	}

	.social-icons a {
		color: var(--text-muted, #9ca3af);
		transition: color 0.2s ease, transform 0.2s ease;
	}

	.social-icons a:hover {
		color: #ffffff;
		transform: translateY(-2px);
	}

	/* --- Bottom Section --- */
	.footer-divider {
		border: none;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		margin-bottom: var(--space-md, 1.5rem);
	}

	.footer-bottom {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
		color: var(--text-muted, #9ca3af);
		font-size: 0.85rem;
	}

	.copyright {
		margin: 0;
	}

	.legal-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		gap: 1.5rem;
	}

	.legal-links a {
		color: var(--text-muted, #9ca3af);
		text-decoration: none;
		transition: color 0.2s ease;
	}

	.legal-links a:hover {
		color: #ffffff;
	}
</style>